generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ============================================
// MODELO DE KITOT (Grupos por año)
// ============================================

model Kita {
  id            String   @id @default(cuid())
  nombre        String   @unique // "najshon", "shinun", "heschel"
  nombreDisplay String            // "Najshón", "Shinun", "Heschel"
  anio          Int               // 1, 2, 3
  passwordHash  String            // Password de acceso para mejanjim
  colorHex      String   @default("#3B82F6")
  activa        Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  talmidim Talmid[]
  clases   ClaseKita[]

  @@map("kitot")
}

model ClaseKita {
  id        String   @id @default(cuid())
  claseId   String
  kitaId    String
  createdAt DateTime @default(now())

  clase Clase @relation(fields: [claseId], references: [id], onDelete: Cascade)
  kita  Kita  @relation(fields: [kitaId], references: [id], onDelete: Cascade)

  @@unique([claseId, kitaId])
  @@map("clase_kita")
}

// ============================================
// MODELOS PRINCIPALES
// ============================================

model Talmid {
  id              String       @id @default(cuid())
  nombre          String
  apellido        String
  fechaNacimiento DateTime?
  telefono        String?
  email           String?      @unique
  fotoUrl         String?
  activo          Boolean      @default(true)
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt

  // Campos para autenticación de talmidim (SoyTalmid)
  passwordHash    String?
  lastLogin       DateTime?

  // Relación con Kitá
  kitaId String?
  kita   Kita?   @relation(fields: [kitaId], references: [id])

  asistencias          Asistencia[]
  notas                Nota[]
  feedbacks            Feedback[]
  pushSubscriptions    PushSubscription[]
  ausenciasProgramadas AusenciaProgramada[]

  @@map("talmidim")
}

model Nota {
  id        String   @id @default(cuid())
  talmidId  String
  categoria String   // "academico", "conducta", "salud", "general"
  contenido String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  talmid Talmid @relation(fields: [talmidId], references: [id], onDelete: Cascade)

  @@map("notas")
}

model Docente {
  id        String   @id @default(cuid())
  nombre    String
  apellido  String
  tipo      String   @default("mejanej") // "mejanej" | "capacitador"
  activo    Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  clases ClaseDocente[]

  @@map("docentes")
}

model ClaseDocente {
  id        String   @id @default(cuid())
  claseId   String
  docenteId String
  createdAt DateTime @default(now())

  clase   Clase   @relation(fields: [claseId], references: [id], onDelete: Cascade)
  docente Docente @relation(fields: [docenteId], references: [id], onDelete: Cascade)

  @@unique([claseId, docenteId])
  @@map("clase_docente")
}

model Clase {
  id          String       @id @default(cuid())
  tipo        String       @default("clase") // "clase" | "evento"
  fecha       DateTime     // Puede haber múltiples clases/eventos en la misma fecha
  diaSemana   String       // "martes", "viernes", o cualquier día para eventos
  horaInicio  String       // "18:30" o "17:30"
  horaFin     String       // "20:30" o "21:00"
  titulo      String?      // titulo/tema de la clase o nombre del evento
  cancelada   Boolean      @default(false)
  motivo      String?      // motivo de cancelacion si aplica
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  docentes    ClaseDocente[]
  asistencias Asistencia[]
  feedbacks   Feedback[]
  kitot       ClaseKita[]  // Relación N:M con kitot (para clases compartidas)

  @@map("clases")
}

model Asistencia {
  id            String   @id @default(cuid())
  talmidId      String
  claseId       String
  estado        String   // "presente", "ausente", "tardanza"
  justificacion String?  // obligatorio si estado = "ausente"
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  talmid Talmid @relation(fields: [talmidId], references: [id], onDelete: Cascade)
  clase  Clase  @relation(fields: [claseId], references: [id], onDelete: Cascade)

  @@unique([talmidId, claseId])
  @@map("asistencias")
}

model Feriado {
  id     String   @id @default(cuid())
  fecha  DateTime @unique
  nombre String
  tipo   String   // "argentino", "judio", "manual"

  @@map("feriados")
}

model AusenciaProgramada {
  id            String   @id @default(cuid())
  talmidId      String
  fechaInicio   DateTime
  fechaFin      DateTime
  justificacion String
  activa        Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  talmid Talmid @relation(fields: [talmidId], references: [id], onDelete: Cascade)

  @@map("ausencias_programadas")
}

model Config {
  id       String @id @default(cuid())
  clave    String @unique
  valor    String

  @@map("config")
}

// ============================================
// MODELOS PARA SOYTALMID (Sistema de Feedback)
// ============================================

// Código de invitación para auto-registro de talmidim
model InviteCode {
  id           String   @id @default(cuid())
  code         String   @unique
  activo       Boolean  @default(true)
  usosMax      Int?     // null = ilimitado
  usosActuales Int      @default(0)
  createdAt    DateTime @default(now())

  @@map("invite_codes")
}

// Suscripciones push para notificaciones
model PushSubscription {
  id        String   @id @default(cuid())
  talmidId  String
  endpoint  String   @unique
  p256dh    String
  auth      String
  createdAt DateTime @default(now())

  talmid Talmid @relation(fields: [talmidId], references: [id], onDelete: Cascade)

  @@map("push_subscriptions")
}

// Feedback de clase (con nombre visible - no anónimo)
model Feedback {
  id               String   @id @default(cuid())
  talmidId         String
  claseId          String
  claseRating      Int      // 1-5 estrellas
  claseComentario  String?
  docentesFeedback String?  // JSON: [{docenteId, rating, comentario}]
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  talmid Talmid @relation(fields: [talmidId], references: [id], onDelete: Cascade)
  clase  Clase  @relation(fields: [claseId], references: [id], onDelete: Cascade)

  @@unique([talmidId, claseId])
  @@map("feedbacks")
}

// Cola de notificaciones para enviar push
model NotificationQueue {
  id           String    @id @default(cuid())
  talmidId     String
  claseId      String
  tipo         String    // "inicial" | "recordatorio"
  scheduledFor DateTime
  sent         Boolean   @default(false)
  sentAt       DateTime?
  createdAt    DateTime  @default(now())

  @@index([scheduledFor, sent])
  @@map("notification_queue")
}
