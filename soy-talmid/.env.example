# Base de datos (misma que presentismo-majon)
DATABASE_URL="postgresql://usuario:password@host:5432/database"

# VAPID keys para notificaciones push
# Generar con: npx web-push generate-vapid-keys
VAPID_PUBLIC_KEY=""
